#!/usr/bin/env bash
# bazzite-mx group setup. Runs once at first boot via the
# bazzite-mx-groups.service oneshot unit. Idempotent and versioned:
# bumping GROUP_SETUP_VER causes the script to re-run.
#
# Why a script and not a build-time `groupadd`: on bootc atomic distros
# /etc/group is part of /etc which is preserved across upgrades.
# Adding users to a group at build-time would only affect the image's
# stub /etc, not real user accounts. This service runs at boot, when
# real wheel users exist, and grants them the relevant privileges.

set -euo pipefail

GROUP_SETUP_VER=1
GROUP_SETUP_VER_FILE="/etc/bazzite-mx/groups-version"

mkdir -p "$(dirname "$GROUP_SETUP_VER_FILE")"

GROUP_SETUP_VER_RAN=$(cat "$GROUP_SETUP_VER_FILE" 2>/dev/null || echo "0")
if [[ "$GROUP_SETUP_VER" == "$GROUP_SETUP_VER_RAN" ]]; then
    echo "bazzite-mx group setup already ran (version $GROUP_SETUP_VER). Exiting."
    exit 0
fi

# Append a group from /usr/lib/group (vendor) into /etc/group (mutable)
# if it isn't there yet. Required because atomic distros only seed
# /etc/group with a minimal subset; package-installed groups land in
# /usr/lib/group and need to be merged at runtime.
append_group() {
    local group_name="$1"
    if ! grep -q "^${group_name}:" /etc/group; then
        if grep -q "^${group_name}:" /usr/lib/group 2>/dev/null; then
            echo "Appending ${group_name} to /etc/group"
            grep "^${group_name}:" /usr/lib/group >> /etc/group
        else
            echo "WARNING: group ${group_name} not found in /usr/lib/group; skipping"
            return 0
        fi
    fi
}

# Groups granted to wheel users by bazzite-mx
TARGET_GROUPS=(docker libvirt)

for g in "${TARGET_GROUPS[@]}"; do
    append_group "$g"
done

# Add every wheel user to the target groups
mapfile -t WHEEL_USERS < <(getent group wheel | cut -d ':' -f 4 | tr ',' '\n' | grep -v '^$' || true)
for user in "${WHEEL_USERS[@]}"; do
    for g in "${TARGET_GROUPS[@]}"; do
        if getent group "$g" >/dev/null; then
            echo "Adding ${user} to ${g}"
            usermod -aG "$g" "$user"
        fi
    done
done

echo "$GROUP_SETUP_VER" > "$GROUP_SETUP_VER_FILE"
echo "bazzite-mx group setup complete (version $GROUP_SETUP_VER)."
